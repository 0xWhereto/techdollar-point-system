## ----- Network -----
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
ETH_CHAIN_ID=42161

## ----- TechDollar protocol addresses -----
USDTE_TOKEN_ADDRESS=0x7d03aa7584889f6e63039B06e408F278f990Bd3F
SUSDTE_TOKEN_ADDRESS=0xc611221C5DF7aC39EC25451cbd1dFA4f271124D4
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

## ----- Curve (paste in once the official USDte pool ships) -----
CURVE_POOL_ADDRESS=0x7f90122BF0700F9E7e1F688fe926940E8839F353
CURVE_LP_TOKEN_ADDRESS=
CURVE_GAUGE_ADDRESS=

## ----- Morpho (paste in once the vault / market ships) -----
MORPHO_VAULT_ADDRESS=
MORPHO_MARKET_ID=
MORPHO_BLUE_ADDRESS=0x6c247b1F6182318877311737BaC0844bAa518F5e
MORPHO_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_clx0lkjn83qet01w69wii1d5w/subgraphs/morpho-blue-arbitrum/1.0.0/gn

## ----- Indexer behaviour -----
POINTS_INDEXER_ENABLED=true
POINTS_INDEXER_TICK_MS=60000
POINTS_EVENT_BLOCK_RANGE=5000
POINTS_RPC_CONCURRENCY=10
POINTS_SNAPSHOT_BATCH=500

## ----- Mint bonus (one-shot) -----
# Points awarded per USDte minted, BEFORE the source.multiplier (which is 1× for mint).
# Tunable per-season via PointSource.extraConfig.pointsPerMint without a migration.
POINTS_PER_USDTE_MINTED=10

## ----- Season setup (Ethena-style) -----
POINTS_SIMULATION_START_AT=2026-04-01T00:00:00Z
POINTS_LAUNCH_AT=2026-05-01T00:00:00Z

## ----- Database (defaults to local SQLite) -----
USE_LOCAL_DB=true
# Leave SQLITE_PATH unset to use ./database.sqlite, or set to ':memory:' for tests.
SQLITE_PATH=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techdollar_points
DB_USER=postgres
DB_PASSWORD=

## ----- Auth (only for the admin routes) -----
JWT_SECRET=change-me-in-production
# Optional shortcut: an exact bearer that bypasses JWT verify and counts as admin.
POINTS_ADMIN_TOKEN=
